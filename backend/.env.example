# === LLM Provider (pick one) ===

# Option 1: OpenAI (preferred)
OPENAI_API_KEY=
MODEL_ID=gpt-4o-mini

# Option 2: Ollama (free, local — used when OPENAI_API_KEY is unset/empty)
# Ensure Ollama is running: ollama serve
# Pull the chat model:    ollama pull llama3.1:8b
# Pull the embed model:   ollama pull nomic-embed-text
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text

# === LangSmith Tracing (optional) ===
# Sign up free at https://smith.langchain.com, then enable tracing:
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your-key-here
# LANGCHAIN_PROJECT=employee-onboarding-agent
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === General ===
CORS_ORIGINS=http://localhost:3000
MAX_TOKENS=4096
AUTO_APPROVE_SECONDS=30
