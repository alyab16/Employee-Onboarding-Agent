# === LLM Provider (pick one) ===

# Option 1: OpenAI (preferred)
OPENAI_API_KEY=sk-your-openai-key-here
MODEL_ID=gpt-4o-mini

# Option 2: Ollama (free, local — used when OPENAI_API_KEY is unset/empty)
# Make sure Ollama is running: ollama serve
# And pull a model: ollama pull llama3.1:8b
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://localhost:11434

# === General ===
CORS_ORIGINS=http://localhost:3000
MAX_TOKENS=4096
# Seconds before manager approval auto-approves (demo)
AUTO_APPROVE_SECONDS=30
